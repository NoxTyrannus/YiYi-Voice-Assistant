{
  "name": "yiyi-assistant",
  "version": "1.0.0",
  "description": "YiYi智能语音助手",
  "main": "src/main/index.js",
  "author": "YiYi Team",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "better-sqlite3": "^9.2.0",
    "cron": "^3.1.0",
    "electron-store": "^8.1.0",
    "node-schedule": "^2.1.1"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.yiyi.assistant",
    "productName": "YiYi",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        }
      ],
      "extendInfo": {
        "LSUIElement": true
      }
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "afterAllArtifactBuild": "./scripts/post-build.js"
  }
}
